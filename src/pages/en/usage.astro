---
import UsagePanel from '../../components/UsagePanel';
import { t } from '../../i18n';
import { localeFromPath } from '../../i18n/routing';
import MainLayout from '../../layouts/MainLayout.astro';
const locale = localeFromPath(Astro.url.pathname);
const initialTab = Astro.url.searchParams.get('tab');
---
<MainLayout title={t(locale, 'usage.pageTitle')} locale={locale}>
  <UsagePanel locale={locale} initialTab={initialTab} client:load />
</MainLayout>
