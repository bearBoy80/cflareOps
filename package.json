{
  "name": "cloudflareops",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist --port 4321",
    "deploy": "astro build && wrangler pages deploy ./dist",
    "typecheck": "astro check && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest run",
    "db:migrate": "wrangler d1 migrations apply cloudflareops-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cloudflareops-db --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/react": "^4.0.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-codemirror": "^4.25.10",
    "astro": "^5.0.0",
    "cloudflare": "^6.1.0",
    "daisyui": "^5.0.0",
    "dayjs": "^1.11.21",
    "jose": "^5.9.0",
    "lucide-react": "^0.525.0",
    "p-limit": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@biomejs/biome": "2.5.2",
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "better-sqlite3": "^11.5.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.107.0"
  }
}
